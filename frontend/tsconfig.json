{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"composite": false,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"baseUrl": "./src",
		"paths": {
			"@app/*": ["app/*"],
			"@pages/*": ["pages/*"],
			"@widgets/*": ["widgets/*"],
			"@features/*": ["features/*"],
			"@entities/*": ["entities/*"],
			"@shared/*": ["shared/*"]
		}
	},
	"include": ["src/**/*"]
}
