# --- Backend ---
# Порт HTTP-сервера
PORT=3000
# Окружение: development | production | test
NODE_ENV=development
# Разрешённые источники для CORS (через запятую). По умолчанию — Vite dev-сервер.
CORS_ORIGIN=http://localhost:5173
# Окно rate-limit в миллисекундах и максимум запросов в окне на IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
# Максимальный размер JSON-body
JSON_BODY_LIMIT=100kb

# --- Frontend ---
# Базовый URL backend API для фронтенда (Vite)
VITE_API_BASE_URL=http://localhost:3000/api
